generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Trial {
  id                     Int                     @id @default(autoincrement())
  userId                 String
  startTime              DateTime                @default(now())
  active                 Boolean                 @default(true)
  passed                 Boolean?                @default(false)
  startedById            String
  guildId                String
  attendanceReminderLogs AttendanceReminderLog[]
  feedbacks              Feedback[]

  @@index([guildId])
  @@index([guildId, active])
  @@index([guildId, userId])
}

model Feedback {
  id                 Int      @id @default(autoincrement())
  trialId            Int
  officerId          String
  performance        Int
  attitude           Int
  focus              Int
  late               Boolean
  comments           String?
  createdAt          DateTime @default(now())
  guildId            String
  raidAttendanceDate String?
  trial              Trial    @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([trialId])
  @@index([guildId, trialId])
  @@index([guildId, raidAttendanceDate])
}

model Settings {
  id                              Int     @id @default(autoincrement())
  guildId                         String  @unique
  trialRoleId                     String
  raiderRoleId                    String
  officerChannelId                String
  raidScheduleCron                String?
  raidAttendanceReminderThreshold Int?
}

model AttendanceReminderLog {
  id              Int      @id @default(autoincrement())
  guildId         String
  trialId         Int
  userId          String
  reminderDate    String
  attendanceCount Int
  createdAt       DateTime @default(now())
  trial           Trial    @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@unique([guildId, trialId, userId, reminderDate])
  @@index([guildId, reminderDate])
  @@index([guildId, userId])
}
