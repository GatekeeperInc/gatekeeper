// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Trial {
  id        Int        @id @default(autoincrement())
  guildId   String
  userId    String
  startTime DateTime   @default(now())
  active    Boolean    @default(true)
  passed    Boolean?   @default(false)
  startedById String
  feedbacks Feedback[]
  attendanceReminderLogs AttendanceReminderLog[]

  @@unique([guildId, userId, active])
  @@index([guildId])
  @@index([guildId, active])
  @@index([guildId, userId])
}

model Feedback {
  id          Int      @id @default(autoincrement())
  guildId     String
  trialId     Int
  officerId   String
  performance Int
  attitude    Int
  focus       Int
  late        Boolean
  comments    String?
  raidAttendanceDate String?
  createdAt   DateTime @default(now())

  trial Trial @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([trialId])
  @@index([guildId, trialId])
  @@index([guildId, raidAttendanceDate])
}

model Settings { 
  id Int @id @default(autoincrement())
  guildId String @unique
  trialRoleId String
  raiderRoleId String
  officerChannelId String
  raidScheduleCron String?
  raidAttendanceReminderThreshold Int?
}

model AttendanceReminderLog {
  id Int @id @default(autoincrement())
  guildId String
  trialId Int
  userId String
  reminderDate String
  attendanceCount Int
  createdAt DateTime @default(now())

  trial Trial @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@unique([guildId, trialId, userId, reminderDate])
  @@index([guildId, reminderDate])
  @@index([guildId, userId])
}
